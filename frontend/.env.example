# --- App Settings ---
# The title used in the browser tab and HTML metadata
VITE_APP_TITLE="TG MiniApp Example"

# --- API Configuration ---
# DEV: Set to "/" to use Vite's internal proxy (prevents CORS issues)
# PROD: Set to your actual production domain (e.g., https://api.myapp.com)
VITE_API_URL="/"

# The URL where your frontend is accessible (used for deep-linking/callbacks)
VITE_FRONTEND_URL="http://localhost:5173"

# --- Telegram Integration ---
# Your Telegram Bot Link with the StartApp parameter
VITE_TG_MINIAPP_START="https://t.me/your_bot_name?startapp"

# --- Yandex OAuth ---
# Yandex OAuth Client ID
VITE_YACID="your_yandex_client_id"

# --- Maintenance Mode ---
# Set to "true" to freeze API requests and show a "Under Construction" overlay
VITE_CONSTRUCTION_MODE=""

# --- Docker / Dev Proxy Only ---
# This variable is used in vite.config.ts to tell the Dev Server where the backend is.
# Use the Docker service name (e.g., http://backend:8000) inside Docker.
VITE_API_PROXY="http://backend:8000"