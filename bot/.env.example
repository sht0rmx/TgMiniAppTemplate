# --- Telegram Bot Configuration ---
# Get your token from @BotFather on Telegram
BOT_TOKEN="your_bot_token_here"

# --- Backend Integration ---
# Internal Docker network URL (e.g., http://backend:8000)
# Ensure the trailing slash is consistent with your internal routing
API_ENDPOINT="http://backend:8000/"

# The secure API Key used for backend authentication
API_KEY="your_api_key_here"

# --- App Links ---
# The deep link used to trigger your Telegram Mini App
TG_STARTAPP_URL="https://t.me/your_bot_name?startapp"