## backend set-up (Example Configuration)

# Server basics
HOST=0.0.0.0:8000

# Security CORS
# Comma-separated list of allowed origins (Dev, Dev Tunnels, Production)
CORS_ORIGINS="http://localhost:5173,https://your-dev-tunnel.ms"

# Security TOKENS
# Get this from @BotFather on Telegram
BOT_TOKEN="your_telegram_bot_token_here"

# Generated Secrets
# Generate strong random strings (e.g., openssl rand -hex 32)
JWT_SECRET="generate_a_random_hex_string"
LOGIN_SECRET="generate_a_random_hex_string"
REFRESH_SECRET="generate_a_random_hex_string"
RECOVERY_SECRET="generate_a_random_hex_string"
API_SECRET="generate_a_random_hex_string"

# Credentials
# API Token Hash for internal authentication
API_TOKEN_HASH="your_secure_api_hash"

# DB
# Format: postgresql+asyncpg://user:password@hostname:port/dbname
# Use 'db' as hostname when running inside Docker
DATABASE_URL="postgresql+asyncpg://postgres:password@db:5432/app"

# S3 (MinIO or AWS)
# Use 'http://minio:9000' for internal Docker networking with MinIO
S3_REGION="us-east-1"
S3_ENDPOINT="http://minio:9000"
S3_KEY_ID="minio_access_key"
S3_SECRET_ACCESS_KEY="minio_secret_key"
S3_BUCKET="app"

# Redis
# Use 'redis' as host when running inside Docker
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD="password"

# Settings
LOGIN_EXPIRE="5m"
ACCESS_EXPITRE="30m"
REFRESH_EXPIRE="60d"

# Yandex OAuth
# Register your app at https://oauth.yandex.ru/
YANDEX_CLIENT_ID="your_yandex_client_id"
YANDEX_CLIENT_SECRET="your_yandex_client_secret"
# Must match the redirect URI used by the frontend (see VITE_YANDEX_REDIRECT_URI), e.g. http://localhost:5173/login
YANDEX_REDIRECT_URI="http://localhost:5173/login"

# Set to "true" for extra logging/debug mode
DEV="true"